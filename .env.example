# Users should configure Base URL and API Key from the app UI.
# These environment variables are only fallback values for local tests or private deployments.
# IMAGE_API_BASE_URL=https://your-image-api.example.com/v1
# IMAGE_API_KEY=sk-your-key-here
IMAGE_API_TIMEOUT_MS=1800000

# Fallback aliases are also supported, in priority order:
# LLM_API_BASE_URL / LLM_API_KEY
# OPENAI_BASE_URL or OPENAI_API_BASE_URL / OPENAI_API_KEY
# DEER_API_BASE_URL / DEER_API_KEY / DEER_API_TIMEOUT_MS
PORT=8787

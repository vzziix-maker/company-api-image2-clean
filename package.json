    "test:payload-routing": "node scripts/test-payload-routing.js",
    "test:persistent-history": "node scripts/test-persistent-history.js",
    "test:rate-limit": "node scripts/test-rate-limit.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "vite": "^7.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {}
}

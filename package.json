{
  "name": "deerapi-gpt-image-2-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/clear-dev-ports.js",
    "dev": "concurrently --kill-others --success first \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --strictPort",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:generate": "node scripts/test-generate.js",
    "test:params": "node scripts/test-params.js",
    "test:payload-routing": "node scripts/test-payload-routing.js",
    "test:history-pagination": "node scripts/test-history-pagination.js",
    "test:persistent-history": "node scripts/test-persistent-history.js",
    "test:history-config": "node scripts/test-history-config.js",
    "test:download-filenames": "node scripts/test-download-filenames.js",
    "test:notifications": "node scripts/test-notification-reminders.js",
    "test:reference-draft": "node scripts/test-reference-image-draft-storage.js",
    "test:rate-limit": "node scripts/test-rate-limit.js",
    "test:provider-profiles": "node scripts/test-provider-profiles.js",
    "test:ai-platform": "node scripts/test-ai-platform.js",
    "test:submit-errors": "node scripts/test-submit-error-copy.js",
    "test:security": "node scripts/test-security-controls.js"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "multer": "^2.0.2",
    "radix-ui": "^1.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "undici": "^7.28.0",
    "vite": "^7.2.7"
  }
}
